# Doxyfile — Baguette documentation configuration

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "Baguette"
PROJECT_BRIEF          = "Research MILP + CP hybrid solver (C++20)"
PROJECT_NUMBER         = 0.3.0
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = include README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.hpp *.md
USE_MDFILE_AS_MAINPAGE = README.md

#---------------------------------------------------------------------------
# Output formats
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

#---------------------------------------------------------------------------
# Display
#---------------------------------------------------------------------------
SORT_MEMBER_DOCS       = NO
SHOW_INCLUDE_FILES     = YES
INLINE_SOURCES         = NO

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
QUIET                  = NO
